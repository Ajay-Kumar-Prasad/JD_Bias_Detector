# Anthropic / OpenAI (for rewriter LLM)
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# Rewrite policy
AUTO_REWRITE_MIN_CONFIDENCE=0.85
SUGGESTION_MIN_CONFIDENCE=0.70
CLASSIFIER_CALIBRATION_TEMPERATURE=1.0
 
# Model paths
